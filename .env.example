# ---- Core ----
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ---- Database / cache ----
# When running via docker-compose, host is the service name "db"/"redis".
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/comm_agent
REDIS_URL=redis://redis:6379/0

# ---- Initial super admin (seeded on first run) ----
FIRST_SUPERADMIN_EMAIL=admin@devexhub.com
FIRST_SUPERADMIN_PASSWORD=ChangeMe123!
FIRST_SUPERADMIN_NAME=Super Admin

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Deepgram ----
DEEPGRAM_API_KEY=

# ---- Storage: "local" (default) or "s3" ----
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Bitrix24 ----
BITRIX_PORTAL_URL=https://your-portal.bitrix24.com
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_REDIRECT_URI=http://localhost:8000/api/bitrix/callback
